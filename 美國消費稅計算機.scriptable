{
  "always_run_in_app" : true,
  "icon" : {
    "color" : "teal",
    "glyph" : "magic"
  },
  "name" : "美國消費稅計算機",
  "script" : "async function mainUI() {\n  const wv = new WebView()\n\n  const states = {\n    \"California (CA)\": {\n      \"Los Angeles\": 9.50, \"San Francisco\": 8.63, \"San Diego\": 7.75,\n      \"Sacramento\": 8.75, \"San Jose\": 9.25\n    },\n    \"Texas (TX)\": {\n      \"Houston\": 8.25, \"Dallas\": 8.25, \"Austin\": 8.25,\n      \"San Antonio\": 8.25, \"Fort Worth\": 8.25\n    },\n    \"Florida (FL)\": {\n      \"Miami\": 7.00, \"Orlando\": 6.50, \"Tampa\": 7.00,\n      \"Jacksonville\": 7.00, \"Tallahassee\": 7.50\n    },\n    \"New York (NY)\": {\n      \"New York City\": 8.88, \"Buffalo\": 8.75, \"Rochester\": 8.00,\n      \"Albany\": 8.00, \"Syracuse\": 8.00\n    },\n    \"Illinois (IL)\": {\n      \"Chicago\": 10.25, \"Aurora\": 8.25, \"Naperville\": 7.75,\n      \"Joliet\": 9.00, \"Springfield\": 9.75\n    },\n    \"Arizona (AZ)\": {\n      \"Phoenix\": 8.60,\n      \"Tucson\": 8.70,\n      \"Mesa\": 8.30,\n      \"Chandler\": 8.20,\n      \"Scottsdale\": 8.05\n    }\n  }\n\n  function buildKeys() {\n    const keys = [\"7\",\"8\",\"9\",\"4\",\"5\",\"6\",\"1\",\"2\",\"3\",\"0\",\".\",\"⌫\"]\n    let html = \"\"\n    for (let i = 0; i < keys.length; i++) {\n      const k = keys[i]\n      html += '<button onclick=\"press(\\'' + k + '\\')\">' + k + '<\/button>'\n    }\n    return html\n  }\n\n  const html = `\n<html>\n<head>\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n\n<style>\n  body {\n    font-family: -apple-system;\n    text-align: center;\n    margin: 20px;\n    touch-action: manipulation;\n  }\n\n  .display { font-size: 32px; margin: 15px; }\n  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }\n\n  button, select {\n    font-size: 18px;\n    padding: 10px;\n    border-radius: 10px;\n    border: none;\n    background: #eee;\n  }\n\n  .add { background: #d4fcd4; }\n  .clear { background: #ffd6d6; }\n  .mode { margin: 10px 0; background: #dbeafe; }\n\n  .result {\n    margin-top: 15px;\n    background: #e5ffe5;\n    padding: 10px;\n    border-radius: 10px;\n    font-size: 16px;\n    text-align: left;\n  }\n\n  .taxed { color: red; font-weight: bold; }\n\n  .action-row {\n    grid-column: span 3;\n    display: flex;\n    gap: 10px;\n  }\n\n  .action-row button { flex: 1; }\n<\/style>\n<\/head>\n\n<body>\n\n<h2>美國銷售稅計算器 \/ US Sales Tax Calculator<\/h2>\n\n<button class=\"mode\" onclick=\"toggleMode()\" id=\"modeBtn\">\n模式 \/ Mode：單筆 \/ Single\n<\/button>\n\n<div>\n  🗽 州 \/ State：\n  <select id=\"stateSelect\"><\/select>\n<\/div>\n\n<div>\n  🏙 城市 \/ City：\n  <select id=\"citySelect\"><\/select>\n<\/div>\n\n<div id=\"taxRate\">稅率 \/ Tax Rate：--%<\/div>\n\n<div class=\"display\" id=\"display\">$ 0<\/div>\n\n<div class=\"grid\">\n  ${buildKeys()}\n\n  <div class=\"action-row\">\n    <button class=\"add\" onclick=\"calc()\">計算 \/ Calculate<\/button>\n    <button class=\"clear\" onclick=\"clearAll()\">清除 \/ Clear<\/button>\n  <\/div>\n<\/div>\n\n<div class=\"result\" id=\"result\"><\/div>\n\n<script>\n  const states = ${JSON.stringify(states)}\n\n  let currentInput = \"0\"\n  let taxRate = 0\n  let mode = \"single\"\n\n  let items = []\n  let total = 0\n\n  const stateSelect = document.getElementById(\"stateSelect\")\n  const citySelect = document.getElementById(\"citySelect\")\n\n  function updateDisplay(){\n    document.getElementById(\"display\").innerHTML = \"$ \" + currentInput\n  }\n\n  function updateTax(){\n    const s = stateSelect.value\n    const c = citySelect.value\n    taxRate = states[s][c]\n    document.getElementById(\"taxRate\").innerHTML =\n      \"稅率 \/ Tax Rate：\" + taxRate + \"%\"\n  }\n\n  function updateCities(){\n    const s = stateSelect.value\n    let html = \"\"\n    const cities = Object.keys(states[s])\n\n    for (let i = 0; i < cities.length; i++) {\n      html += '<option value=\"' + cities[i] + '\">' + cities[i] + '<\/option>'\n    }\n\n    citySelect.innerHTML = html\n    updateTax()\n  }\n\n  stateSelect.innerHTML = Object.keys(states).map(function(s){\n    return '<option value=\"' + s + '\">' + s + '<\/option>'\n  }).join(\"\")\n\n  stateSelect.onchange = updateCities\n  citySelect.onchange = updateTax\n\n  updateCities()\n\n  function renderItems(){\n    if (mode !== \"sum\") return\n\n    let html = \"<b>📋 明細 \/ Items：<\/b><br>\"\n\n    for (let i = 0; i < items.length; i++) {\n      html += \"#\" + (i+1) + \" - $\" + items[i].toFixed(2) +\n      \" 未含稅 \/ Before Tax\" +\n      ' <button onclick=\"deleteItem(' + i + ')\" style=\"margin-left:8px;background:#ffdddd;border:none;padding:2px 6px;border-radius:6px;\">刪除 \/ Delete<\/button><br>'\n    }\n\n    const taxed = (total * (1 + taxRate\/100)).toFixed(2)\n\n    html += \"<hr>\"\n    html += \"小計 \/ Subtotal：$\" + total.toFixed(2) + \"<br>\"\n    html += \"<span class='taxed'>含稅 \/ Total with Tax：$\" + taxed + \"<\/span>\"\n\n    document.getElementById(\"result\").innerHTML = html\n  }\n\n  window.press = function(k){\n    if (k === \"⌫\") {\n      currentInput = currentInput.slice(0,-1) || \"0\"\n    } else if (k === \".\") {\n      if (!currentInput.includes(\".\")) currentInput += \".\"\n    } else {\n      currentInput = currentInput === \"0\" ? k : currentInput + k\n    }\n\n    updateDisplay()\n  }\n\n  window.calc = function(){\n    const val = parseFloat(currentInput)\n    if (isNaN(val)) return\n\n    if (mode === \"sum\") {\n      items.push(val)\n      total = items.reduce((a,b)=>a+b,0)\n      renderItems()\n    } else {\n      const taxed = (val * (1 + taxRate\/100)).toFixed(2)\n\n      document.getElementById(\"result\").innerHTML =\n        \"未稅 \/ Before Tax：$\" + val.toFixed(2) +\n        \"<br><span class='taxed'>含稅 \/ Total with Tax：$\" + taxed + \"<\/span>\"\n    }\n\n    currentInput = \"0\"\n    updateDisplay()\n  }\n\n  window.deleteItem = function(i){\n    items.splice(i,1)\n    total = items.reduce((a,b)=>a+b,0)\n    renderItems()\n  }\n\n  window.toggleMode = function(){\n    mode = (mode === \"single\") ? \"sum\" : \"single\"\n\n    items = []\n    total = 0\n    currentInput = \"0\"\n\n    document.getElementById(\"modeBtn\").innerHTML =\n      \"模式 \/ Mode：\" + (mode === \"sum\" ? \"加總 \/ Sum\" : \"單筆 \/ Single\")\n\n    document.getElementById(\"result\").innerHTML =\n      mode === \"sum\"\n        ? \"🔢 加總模式 \/ Sum Mode\"\n        : \"🧮 單筆模式 \/ Single Mode\"\n\n    updateDisplay()\n  }\n\n  window.clearAll = function(){\n    items = []\n    total = 0\n    currentInput = \"0\"\n\n    document.getElementById(\"result\").innerHTML =\n      \"🧹 已清除 \/ Cleared\"\n\n    updateDisplay()\n  }\n\n  updateDisplay()\n\n  let lastTouchEnd = 0;\n  document.addEventListener('touchend', function (event) {\n    const now = Date.now();\n    if (now - lastTouchEnd <= 300) {\n      event.preventDefault();\n    }\n    lastTouchEnd = now;\n  }, false);\n\n<\/script>\n\n<\/body>\n<\/html>\n`\n\n  await wv.loadHTML(html)\n  await wv.present()\n}\n\nmainUI()",
  "share_sheet_inputs" : [

  ]
}